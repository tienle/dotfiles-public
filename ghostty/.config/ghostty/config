# Ghostty — tuned for a tmux + Neovim workflow.
# Reference: https://ghostty.org/docs/config/reference

# ── Theme: custom palette matching Neovim's github_dark_tritanopia exactly ──
# (file lives in ./themes/github_dark_tritanopia)
theme = github_dark_tritanopia

# ── Font: JetBrains Mono ships with Ghostty; Nerd Font icons via auto-fallback ──
font-family = JetBrains Mono
font-size = 14
font-thicken = true
# Dislike ligatures? uncomment:
# font-feature = -calt,-liga,-dlig

# ── Cursor: solid block, no blink (calm) ──
cursor-style = block
cursor-style-blink = false

# ── macOS: send Alt/Meta on Option — required for tmux & Neovim Meta maps ──
macos-option-as-alt = true

# ── Window chrome: minimal ──
macos-titlebar-style = tabs
window-padding-x = 8
window-padding-y = 6
window-padding-balance = true
window-save-state = always
# Translucent background (optional): set opacity < 1 and uncomment the blur
background-opacity = 1.0
# background-blur-radius = 20

# ── Behavior ──
mouse-hide-while-typing = true
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
# tmux keeps your sessions safe, so skip the close confirmation
confirm-close-surface = false
window-inherit-working-directory = true

# ── Shell integration: cwd reporting + prompt marks (cursor handled above) ──
shell-integration = detect
shell-integration-features = no-cursor,sudo,title

# tmux owns multiplexing, so Ghostty's default keybinds are left as-is.
# Reload this file any time with cmd+shift+,
