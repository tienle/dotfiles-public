# Telegram notifications for tmux-agent-status (OPTIONAL).
#
# Copy this to ~/.config/claude/telegram.env and chmod 600. The real file lives
# OUTSIDE this repo and is never committed (it holds a bot token).
#
#   mkdir -p ~/.config/claude
#   cp telegram.env.example ~/.config/claude/telegram.env
#   chmod 600 ~/.config/claude/telegram.env
#   # then edit in your real values:
#
# Get a token: message @BotFather -> /newbot -> copy the token.
# Get your chat_id: message your new bot once, then:
#   curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq '.result[].message.chat.id'
#
# If this file is absent, notify-telegram.sh is a silent no-op.

TELEGRAM_BOT_TOKEN=123456789:AA-replace-with-your-botfather-token
TELEGRAM_CHAT_ID=987654321
